# Copy to .env and fill in. docker compose reads .env automatically.

# Required: bearer token guarding every /v1 route (and /metrics).
# Generate one: openssl rand -hex 32
RUWA_API_TOKEN=

# Optional: enable AES-256-GCM encryption at rest for the sensitive DB columns.
# Must be 32 bytes, base64-encoded. Generate one: openssl rand -base64 32
# Leave blank to store unencrypted (e.g. when the volume is on an encrypted disk).
RUWA_DB_ENCRYPTION_KEY=

# Optional: log level (error|warn|info|debug|trace).
RUST_LOG=info

# Optional: WhatsApp Web client version override ("a.b.c", all numeric). If
# WhatsApp starts rejecting logins with <failure reason="405"> ("client
# outdated"), set this to a current WA Web version without rebuilding.
# RUWA_WA_VERSION=

# Optional but RECOMMENDED for agent/MCP deployments: confine `POST
# /messages/media` file_path sends to this directory. When set, a file_path
# resolving outside it is rejected (blocks path-traversal / file exfiltration
# under prompt injection). Unset = full-filesystem access (operator's choice).
# RUWA_MEDIA_BASE_DIR=/srv/ruwa/media

# Optional: cross-instance leasing (set RUWA_LEASING=1 to enable).
# RUWA_LEASING=1
# RUWA_INSTANCE_ID=
# RUWA_LEASE_TTL_SECS=60

# Optional: retention sweep (all default off).
# RUWA_RETENTION_SWEEP_SECS=21600
# RUWA_RETENTION_MESSAGES_PER_CHAT=5000
# RUWA_RETENTION_MESSAGE_DAYS=90
# RUWA_RETENTION_SIGNAL_DAYS=180

# Optional: media storage. Default "db" keeps media blobs in the database.
# Set "s3" to offload to an S3-compatible bucket (MinIO/AWS S3/Cloudflare R2)
# via the in-house SigV4 client; the RUWA_S3_* vars are then required.
# RUWA_MEDIA_STORE=s3
# RUWA_S3_ENDPOINT=http://minio:9000
# RUWA_S3_BUCKET=wa-media
# RUWA_S3_REGION=us-east-1
# RUWA_S3_ACCESS_KEY=
# RUWA_S3_SECRET_KEY=
# Public base URL for serving objects (CDN / R2). Falls back to
# {endpoint}/{bucket}/{key} path-style when unset.
# RUWA_S3_PUBLIC_BASE_URL=
